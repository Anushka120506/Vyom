NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB — replace with your Atlas URI or local instance
MONGODB_URI=mongodb://localhost:27017/vyom

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# AI Engine (Python Flask) — optional, used for model blending
AI_ENGINE_URL=http://localhost:8000
